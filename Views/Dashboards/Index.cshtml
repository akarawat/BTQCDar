@model BTQCDar.Models.UserSessionModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="row mt-3 g-3">

    <!-- Welcome card -->
    <div class="col-12">
        <div class="card border-0 shadow-sm">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="text-danger" style="font-size:3rem;">
                    <i class="bi bi-file-earmark-check-fill"></i>
                </div>
                <div>
                    <h4 class="mb-0">Welcome, @Model.FullName</h4>
                    <small class="text-muted">@Model.SamAcc &nbsp;|&nbsp; @Model.DepName</small>
                    @if (!string.IsNullOrEmpty(Model.ManagerName))
                    {
                        <div class="small text-muted">Manager: @Model.ManagerName</div>
                    }
                </div>
                <div class="ms-auto text-end">
                    @if (Model.IsAdmin)
                    {
                        <span class="badge bg-warning text-dark">Admin</span>
                    }
                    @if (Model.IsMR)
                    {
                        <span class="badge bg-info text-dark">MR</span>
                    }
                    @if (Model.IsDCO)
                    {
                        <span class="badge bg-primary">DCO</span>
                    }
                    @if (Model.IsDarApprover)
                    {
                        <span class="badge bg-success">Approver</span>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Quick-action cards -->
    <div class="col-sm-6 col-md-3">
        <a href="/Dar/Create" class="text-decoration-none">
            <div class="card border-0 shadow-sm h-100 text-center p-3 hover-lift">
                <div class="display-5 text-danger mb-2"><i class="bi bi-plus-circle-fill"></i></div>
                <div class="fw-semibold">New DAR</div>
                <small class="text-muted">Create a document action request</small>
            </div>
        </a>
    </div>

    <div class="col-sm-6 col-md-3">
        <a href="/Dar/Index" class="text-decoration-none">
            <div class="card border-0 shadow-sm h-100 text-center p-3">
                <div class="display-5 text-primary mb-2"><i class="bi bi-list-ul"></i></div>
                <div class="fw-semibold">My DARs</div>
                <small class="text-muted">My requests</small>
            </div>
        </a>
    </div>
    <div class="col-sm-6 col-md-3">
        <a href="/Dar/History" class="text-decoration-none">
            <div class="card border-0 shadow-sm h-100 text-center p-3">
                <div class="display-5 text-secondary mb-2"><i class="bi bi-clock-history"></i></div>
                <div class="fw-semibold">History</div>
                <small class="text-muted">Documents I have signed</small>
            </div>
        </a>
    </div>
    <div class="col-sm-6 col-md-3">
        <a href="/Dar/Pending" class="text-decoration-none">
            <div class="card border-0 shadow-sm h-100 text-center p-3 position-relative">
                <div class="display-5 text-warning mb-2"><i class="bi bi-inbox-fill"></i></div>
                <div class="fw-semibold">Pending Actions</div>
                <small class="text-muted">Awaiting your approval</small>
                <span id="dashPendingBadge"
                      class="position-absolute top-0 end-0 mt-2 me-2 badge rounded-pill bg-danger"
                      style="display:none;font-size:0.8rem"></span>
            </div>
        </a>
    </div>

    <div class="col-sm-6 col-md-3">
        <div class="card border-0 shadow-sm h-100 text-center p-3 bg-light">
            <div class="display-5 text-secondary mb-2"><i class="bi bi-journal-check"></i></div>
            <div class="fw-semibold text-muted">DAR System</div>
            <small class="text-muted">FM-MR-001 Rev.03</small>
        </div>
    </div>

</div>
