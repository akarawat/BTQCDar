@model BTQCDar.Models.UserSessionModel
@{ ViewData["Title"] = "หน้าหลัก"; }

<div class="row mt-3 g-3">
    <!-- Welcome card -->
    <div class="col-12">
        <div class="card border-0 shadow-sm">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="text-danger" style="font-size:3rem;"><i class="bi bi-file-earmark-check-fill"></i></div>
                <div>
                    <h4 class="mb-0">สวัสดี, @Model.FullName</h4>
                    <small class="text-muted">@Model.SamAcc &nbsp;|&nbsp; @Model.Dept</small>
                    @if (!string.IsNullOrEmpty(Model.ManagerName))
                    {
                        <div class="small text-muted">ผู้บังคับบัญชา: @Model.ManagerName</div>
                    }
                </div>
                <div class="ms-auto text-end">
                    @if (Model.IsAdmin) { <span class="badge bg-warning text-dark">Admin</span> }
                    @if (Model.IsMR)    { <span class="badge bg-info text-dark">MR</span> }
                    @if (Model.IsDCO)   { <span class="badge bg-primary">DCO</span> }
                    @if (Model.IsDarApprover) { <span class="badge bg-success">Approver</span> }
                </div>
            </div>
        </div>
    </div>

    <!-- Quick-action cards -->
    <div class="col-sm-6 col-md-3">
        <a href="/Dar/Create" class="text-decoration-none">
            <div class="card border-0 shadow-sm h-100 text-center p-3 hover-lift">
                <div class="display-5 text-danger mb-2"><i class="bi bi-plus-circle-fill"></i></div>
                <div class="fw-semibold">สร้าง DAR ใหม่</div>
                <small class="text-muted">New Document Action Request</small>
            </div>
        </a>
    </div>
    <div class="col-sm-6 col-md-3">
        <a href="/Dar/Index" class="text-decoration-none">
            <div class="card border-0 shadow-sm h-100 text-center p-3">
                <div class="display-5 text-primary mb-2"><i class="bi bi-list-ul"></i></div>
                <div class="fw-semibold">DAR ของฉัน</div>
                <small class="text-muted">My requests</small>
            </div>
        </a>
    </div>
    <div class="col-sm-6 col-md-3">
        <a href="/Dar/Pending" class="text-decoration-none">
            <div class="card border-0 shadow-sm h-100 text-center p-3">
                <div class="display-5 text-warning mb-2"><i class="bi bi-inbox-fill"></i></div>
                <div class="fw-semibold">รอดำเนินการ</div>
                <small class="text-muted">Pending approval</small>
            </div>
        </a>
    </div>
    <div class="col-sm-6 col-md-3">
        <div class="card border-0 shadow-sm h-100 text-center p-3 bg-light">
            <div class="display-5 text-secondary mb-2"><i class="bi bi-journal-check"></i></div>
            <div class="fw-semibold text-muted">ระบบ DAR</div>
            <small class="text-muted">FM-MR-001 Rev.03</small>
        </div>
    </div>
</div>
