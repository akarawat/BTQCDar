@model List<BTQCDar.Models.DarListItemModel>
@{ ViewData["Title"] = "รอดำเนินการ"; }

<div class="d-flex align-items-center mt-3 mb-3">
    <h5 class="mb-0"><i class="bi bi-inbox-fill me-1 text-warning"></i>รายการรอดำเนินการ</h5>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0 dar-table">
                <thead>
                    <tr>
                        <th>DAR No.</th>
                        <th>Document Name</th>
                        <th>ผู้ขอ</th>
                        <th>วันที่ขอ</th>
                        <th class="text-center">Status</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr><td colspan="6" class="text-center text-muted py-4">ไม่มีรายการรอดำเนินการ</td></tr>
                    }
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-semibold">@item.DarNo</td>
                            <td>@item.DocumentName</td>
                            <td>@item.RequestedBy</td>
                            <td><small>@item.RequestedDate.ToString("dd/MM/yyyy")</small></td>
                            <td class="text-center">
                                <span class="badge status-pill @item.StatusBadgeClass">@item.StatusLabel</span>
                            </td>
                            <td>
                                <a href="/Dar/Detail/@item.DarId" class="btn btn-sm btn-danger">
                                    <i class="bi bi-pencil-square me-1"></i>ดำเนินการ
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
