@model List<BTQCDar.Models.DarListItemModel>
@{
    ViewData["Title"] = "My DARs";
}

<div class="d-flex align-items-center mt-3 mb-3 gap-2">
    <h5 class="mb-0"><i class="bi bi-list-ul me-1 text-danger"></i>My DARs</h5>
    <a href="/Dar/Create" class="btn btn-danger btn-sm ms-auto">
        <i class="bi bi-plus-circle me-1"></i>New DAR
    </a>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0 dar-table">
                <thead>
                    <tr>
                        <th>DAR No.</th>
                        <th>Document No.</th>
                        <th>Document Name</th>
                        <th>Purpose</th>
                        <th>Request Date</th>
                        <th class="text-center">Status</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="7" class="text-center text-muted py-4">
                                No DAR records found.
                            </td>
                        </tr>
                    }
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-semibold">@item.DarNo</td>
                            <td>@item.DocumentNo</td>
                            <td>@item.DocumentName</td>
                            <td><small>@item.Purpose</small></td>
                            <td><small>@item.RequestedDate.ToString("dd/MM/yyyy")</small></td>
                            <td class="text-center">
                                <span class="badge status-pill @item.StatusBadgeClass">@item.StatusLabel</span>
                            </td>
                            <td>
                                <a href="/Dar/Detail/@item.DarId" class="btn btn-sm btn-outline-secondary">
                                    <i class="bi bi-eye"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
