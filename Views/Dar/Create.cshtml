@model BTQCDar.Models.DarMasterModel
@{
    ViewData["Title"] = "Create New DAR";
    var session = ViewBag.Session as BTQCDar.Models.UserSessionModel;
}

<div class="d-flex justify-content-between align-items-center mt-3 mb-3">
    <h5 class="mb-0"><i class="bi bi-plus-circle me-2"></i>Create New DAR</h5>
    <a href="/Dar/Index" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i>Back
    </a>
</div>

<form asp-action="Create" method="post" enctype="multipart/form-data" id="frmDar">
    @Html.AntiForgeryToken()

    <!-- ════ Type ════ -->
    <div class="card shadow-sm mb-3">
        <div class="card-header bg-danger text-white fw-semibold">
            <i class="bi bi-tag me-2"></i>Type <span class="text-warning ms-1">*</span>
        </div>
        <div class="card-body">
            <div class="row g-3">
                <!-- Radio group wrapper — gets red border when invalid -->
                <div class="col-md-6" id="grpDocType">
                    <div class="form-check">
                        <input class="form-check-input" type="radio" asp-for="DocType" value="1" id="dt1">
                        <label class="form-check-label" for="dt1">Policy / Objective / Manual</label>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="radio" asp-for="DocType" value="3" id="dt3">
                        <label class="form-check-label" for="dt3">(Work/Inspection) Instruction</label>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="radio" asp-for="DocType" value="5" id="dt5">
                        <label class="form-check-label" for="dt5">Supporting Document</label>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="radio" asp-for="DocType" value="7" id="dt7">
                        <label class="form-check-label" for="dt7">Document from External Origin</label>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-check">
                        <input class="form-check-input" type="radio" asp-for="DocType" value="2" id="dt2">
                        <label class="form-check-label" for="dt2">Standard Procedure</label>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="radio" asp-for="DocType" value="4" id="dt4">
                        <label class="form-check-label" for="dt4">Form and Format</label>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="radio" asp-for="DocType" value="6" id="dt6">
                        <label class="form-check-label" for="dt6">Drawing</label>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="radio" asp-for="DocType" value="8" id="dt8">
                        <label class="form-check-label" for="dt8">Other (Specify)</label>
                    </div>
                </div>
                <div id="dtInvalidMsg" class="col-12 text-danger small" style="display:none">
                    <i class="bi bi-exclamation-circle me-1"></i>Please select a document type.
                </div>
                <div class="col-12" id="dtOtherWrap" style="display:none">
                    <input type="text" asp-for="DocTypeOther" class="form-control form-control-sm"
                           placeholder="Specify document type...">
                </div>

                <!-- For standard -->
                <div class="col-12 border-top pt-3">
                    <label class="fw-semibold small text-muted mb-2">
                        For <span class="text-danger">*</span>
                    </label>
                    <div id="grpForStandard" class="d-flex flex-wrap gap-3">
                        <div class="form-check">
                            <input class="form-check-input" type="radio" asp-for="ForStandard" value="1" id="fs1">
                            <label class="form-check-label" for="fs1">QMS / ISO 9001</label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="radio" asp-for="ForStandard" value="2" id="fs2">
                            <label class="form-check-label" for="fs2">EMS / ISO 14001</label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="radio" asp-for="ForStandard" value="3" id="fs3">
                            <label class="form-check-label" for="fs3">Safety / OHSAS / TIS 18001</label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="radio" asp-for="ForStandard" value="4" id="fs4">
                            <label class="form-check-label" for="fs4">Others (specify)</label>
                        </div>
                    </div>
                    <div id="fsInvalidMsg" class="text-danger small mt-1" style="display:none">
                        <i class="bi bi-exclamation-circle me-1"></i>Please select a standard.
                    </div>
                    <div id="fsOtherWrap" class="mt-2" style="display:none">
                        <input type="text" asp-for="ForStandardOther" class="form-control form-control-sm"
                               placeholder="Specify standard...">
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- ════ Document Information ════ -->
    <div class="card shadow-sm mb-3">
        <div class="card-header fw-semibold">
            <i class="bi bi-file-text me-2"></i>Document Information
        </div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label small fw-semibold">Document No</label>
                    <input type="text" asp-for="DocumentNo" class="form-control form-control-sm"
                           placeholder="Document number">
                </div>
                <div class="col-md-8">
                    <label class="form-label small fw-semibold">
                        Document Name <span class="text-danger">*</span>
                    </label>
                    <input type="text" asp-for="DocumentName" class="form-control form-control-sm req-field"
                           placeholder="Document name" required>
                    <div class="invalid-feedback">Please enter the document name.</div>
                </div>
            </div>
        </div>
    </div>

    <!-- ════ Purpose ════ -->
    <div class="card shadow-sm mb-3">
        <div class="card-header fw-semibold">
            <i class="bi bi-bullseye me-2"></i>Purpose <span class="text-danger ms-1">*</span>
        </div>
        <div class="card-body">
            <div id="grpPurpose" class="row g-2">
                <div class="col-md-6">
                    <div class="form-check">
                        <input class="form-check-input" type="radio" asp-for="Purpose" value="1" id="p1">
                        <label class="form-check-label" for="p1">Issue new document</label>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="radio" asp-for="Purpose" value="3" id="p3">
                        <label class="form-check-label" for="p3">Change / Update / Revise</label>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="radio" asp-for="Purpose" value="5" id="p5">
                        <label class="form-check-label" for="p5">Cancel document</label>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-check">
                        <input class="form-check-input" type="radio" asp-for="Purpose" value="2" id="p2">
                        <label class="form-check-label" for="p2">Receive from external origin</label>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="radio" asp-for="Purpose" value="4" id="p4">
                        <label class="form-check-label" for="p4">Add distribution (Control copy)</label>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="radio" asp-for="Purpose" value="6" id="p6">
                        <label class="form-check-label" for="p6">Request copy (Un-Control copy)</label>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="radio" asp-for="Purpose" value="7" id="p7">
                        <label class="form-check-label" for="p7">Others (Specify)</label>
                    </div>
                </div>
            </div>
            <div id="purposeInvalidMsg" class="text-danger small mt-1" style="display:none">
                <i class="bi bi-exclamation-circle me-1"></i>Please select a purpose.
            </div>
            <div id="purposeOtherWrap" class="mt-2" style="display:none">
                <input type="text" asp-for="PurposeOther" class="form-control form-control-sm"
                       placeholder="Specify purpose...">
            </div>
        </div>
    </div>

    <!-- ════ Content & Reason ════ -->
    <div class="card shadow-sm mb-3">
        <div class="card-header fw-semibold">
            <i class="bi bi-card-text me-2"></i>Content &amp; Reason
        </div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-12">
                    <label class="form-label small fw-semibold">
                        Content of Document or Change <span class="text-danger">*</span>
                    </label>
                    <textarea asp-for="Content" class="form-control form-control-sm req-field" rows="4"
                              placeholder="Describe document content or changes..." required></textarea>
                    <div class="invalid-feedback">Please describe the content.</div>
                </div>
                <div class="col-md-6">
                    <label class="form-label small fw-semibold">Status of Document Under Request</label>
                    <input type="text" asp-for="DocStatusUnderRequest" class="form-control form-control-sm"
                           placeholder="Current document status...">
                </div>
                <div class="col-12">
                    <label class="form-label small fw-semibold">Describe Reason Behind Purpose</label>
                    <textarea asp-for="ReasonBehindPurpose" class="form-control form-control-sm" rows="3"
                              placeholder="Explain the reason for this request..."></textarea>
                </div>
                <div class="col-md-4">
                    <label class="form-label small fw-semibold">Effective Date</label>
                    <input type="date" asp-for="EffectiveDate" class="form-control form-control-sm">
                </div>
                <div class="col-md-4">
                    <label class="form-label small fw-semibold">Revision No</label>
                    <input type="text" asp-for="RevisionNo" class="form-control form-control-sm"
                           placeholder="e.g. Rev.01">
                </div>
            </div>
        </div>
    </div>

    <!-- ════ Attachment (File Upload) ════ -->
    <div class="card shadow-sm mb-3">
        <div class="card-header fw-semibold">
            <i class="bi bi-paperclip me-2"></i>Attachment
        </div>
        <div class="card-body">
            <!-- Hidden field — auto-set by JS when file is selected -->
            <input type="hidden" asp-for="HasAttachment" id="hdnHasAttachment" value="false">

            <div class="upload-area border border-2 border-dashed rounded-3 p-4 text-center"
                 id="uploadArea">
                <i class="bi bi-cloud-upload fs-1 text-muted"></i>
                <p class="mb-1 mt-2 fw-semibold">Drag &amp; drop file here, or</p>
                <label class="btn btn-outline-danger btn-sm mt-1" for="attachmentFile">
                    <i class="bi bi-folder2-open me-1"></i>Browse File
                </label>
                <input type="file" name="attachmentFile" id="attachmentFile" class="d-none"
                       accept=".pdf,.doc,.docx,.xls,.xlsx,.png,.jpg,.jpeg,.zip">
                <p class="text-muted small mt-2 mb-0">
                    Accepted: PDF, Word, Excel, Image, ZIP &nbsp;|&nbsp; Max: 20 MB
                </p>
            </div>

            <!-- Preview panel (hidden until file chosen) -->
            <div id="filePreview" class="mt-3" style="display:none">
                <div class="d-flex align-items-center gap-3 p-3 bg-light rounded border">
                    <i class="bi bi-file-earmark fs-2 text-danger" id="fileIcon"></i>
                    <div class="flex-grow-1 overflow-hidden">
                        <div class="fw-semibold text-truncate" id="fileName"></div>
                        <div class="text-muted small" id="fileSize"></div>
                    </div>
                    <button type="button" class="btn btn-outline-danger btn-sm" id="btnRemoveFile"
                            title="Remove file">
                        <i class="bi bi-x-lg"></i>
                    </button>
                </div>
            </div>
        </div>
    </div>


    <!-- ════ Approver Selection ════ -->
    <div class="card shadow-sm mb-3">
        <div class="card-header bg-danger text-white fw-semibold">
            <i class="bi bi-person-check me-2"></i>Approver Selection
            <span class="text-warning ms-1">*</span>
            <span class="badge bg-white text-danger ms-2 float-end" id="approverCount">0 selected</span>
        </div>
        <div class="card-body">

            <!-- Search + Filter bar -->
            <div class="row g-2 mb-3">
                <div class="col-md-5">
                    <div class="input-group input-group-sm">
                        <span class="input-group-text"><i class="bi bi-search"></i></span>
                        <input type="text" id="approverSearch" class="form-control"
                               placeholder="Search name, department...">
                    </div>
                </div>
                <div class="col-md-4">
                    <select id="filterRole" class="form-select form-select-sm">
                        <option value="">-- All Roles --</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <select id="filterDept" class="form-select form-select-sm">
                        <option value="">-- All Departments --</option>
                    </select>
                </div>
            </div>

            <!-- Approver list -->
            <div id="approverListWrap" style="max-height:320px;overflow-y:auto;"
                 class="border rounded">
                <div id="approverLoading" class="text-center text-muted py-4">
                    <div class="spinner-border spinner-border-sm me-2"></div>Loading...
                </div>
                <div id="approverList" style="display:none"></div>
            </div>

            <div id="approverInvalidMsg" class="text-danger small mt-2" style="display:none">
                <i class="bi bi-exclamation-circle me-1"></i>Please select at least one approver.
            </div>

            <!-- Selected summary chips -->
            <div id="selectedChips" class="d-flex flex-wrap gap-2 mt-3"></div>

        </div>
    </div>

    <!-- ════ Distribution List ════ -->
    <div class="card shadow-sm mb-3">
        <div class="card-header fw-semibold">
            <i class="bi bi-people me-2"></i>Distribution List
        </div>
        <div class="card-body">
            <div class="row g-2 mb-3">
                <div class="col-auto">
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" asp-for="IsControlledCopy" id="chkCtrl">
                        <label class="form-check-label" for="chkCtrl">Controlled Copy</label>
                    </div>
                </div>
                <div class="col-auto">
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" asp-for="IsUncontrolledCopy" id="chkUnctrl">
                        <label class="form-check-label" for="chkUnctrl">Uncontrolled Copy</label>
                    </div>
                </div>
            </div>
            <textarea asp-for="DistributionList" class="form-control form-control-sm" rows="3"
                      placeholder="List departments / sections..."></textarea>
        </div>
    </div>

    <!-- ════ Requested By ════ -->
    <div class="card shadow-sm mb-3">
        <div class="card-header fw-semibold">
            <i class="bi bi-person me-2"></i>Requested By
        </div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label small fw-semibold">Full Name</label>
                    <input type="text" class="form-control form-control-sm" value="@session?.FullName" readonly>
                    <input type="hidden" asp-for="RequestedByName"   value="@session?.FullName">
                    <input type="hidden" asp-for="RequestedBySamAcc" value="@session?.SamAcc">
                </div>
                <div class="col-md-6">
                    <label class="form-label small fw-semibold">Request Date</label>
                    <input type="text" class="form-control form-control-sm bg-light"
                           value="@DateTime.Now.ToString("dd/MM/yyyy")" readonly>
                </div>
            </div>
        </div>
    </div>

    <!-- Submit -->
    <div class="d-flex gap-2 justify-content-end mb-4">
        <a href="/Dar/Index" class="btn btn-outline-secondary">
            <i class="bi bi-x-circle me-1"></i>Cancel
        </a>
        <button type="submit" class="btn btn-danger" id="btnSubmit">
            <i class="bi bi-send me-1"></i>Submit DAR
        </button>
    </div>
</form>

@section Styles {
    <style>
        /* Required radio group — error state */
        .radio-group-invalid {
            border: 2px solid #dc3545 !important;
            border-radius: 6px;
            padding: 8px 10px;
            background-color: #fff5f5;
        }

        /* Upload drop zone */
        .upload-area {
            border-color: #dee2e6 !important;
            transition: border-color 0.2s, background-color 0.2s;
            cursor: pointer;
        }
        .upload-area.drag-over {
            border-color: #dc3545 !important;
            background-color: #fff5f5;
        }
        .upload-area.has-file {
            border-color: #198754 !important;
            background-color: #f0fff4;
        }
    </style>
}

@section Scripts {
    <script src="~/js/dar-form.js" asp-append-version="true"></script>
}
