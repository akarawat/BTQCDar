@model BTQCDar.Models.DarMasterModel
@{
    ViewData["Title"] = "DAR: " + Model.DarNo;
    var session = ViewBag.Session as BTQCDar.Models.UserSessionModel;
    // Reviewer — matched by SamAcc stored at Create time
    bool canReview = (string.Equals(session?.SamAcc, Model.ReviewerSamAcc,
                              StringComparison.OrdinalIgnoreCase) || session?.IsAdmin == true)
                         && Model.Status == BTQCDar.Models.DarStatus.PendingApproval
                         && Model.ReviewerSignedAt == null;

    bool canSignReview = canReview;

    // Approver — matched by SamAcc stored at Create time
    bool canApprove = (string.Equals(session?.SamAcc, Model.ApproverSamAcc,
                               StringComparison.OrdinalIgnoreCase) || session?.IsAdmin == true)
                          && Model.ApproverSignedAt == null
                          && (Model.Status == BTQCDar.Models.DarStatus.PendingMR ||
                             (Model.Status == BTQCDar.Models.DarStatus.PendingDCO && Model.ApproverSignedAt == null));

    bool canSignApprove = canApprove;

    // QMR (IsMR/role=2) — agrees while Status=PendingDCO, before MRAgree is set
    bool canMR = (session?.IsMR == true || session?.IsAdmin == true)
                  && Model.Status == BTQCDar.Models.DarStatus.PendingDCO
                  && Model.MRAgree == null;

    // DCC (IsDCO/role=1) — manual "Completed" after QMR has agreed
    bool canDCO = (session?.IsDCO == true || session?.IsAdmin == true)
                  && Model.Status == BTQCDar.Models.DarStatus.PendingDCO
                  && Model.MRAgree == true;

    bool canEdit = (Model.Status == BTQCDar.Models.DarStatus.Draft
                       && Model.RequestedBySamAcc == session?.SamAcc)
                      || session?.IsAdmin == true;

    string badgeClass = Model.Status switch
    {
        BTQCDar.Models.DarStatus.Draft => "bg-secondary",
        BTQCDar.Models.DarStatus.PendingApproval => "bg-warning text-dark",
        BTQCDar.Models.DarStatus.PendingMR => "bg-info text-dark",
        BTQCDar.Models.DarStatus.PendingDCO => "bg-primary",
        BTQCDar.Models.DarStatus.Completed => "bg-success",
        BTQCDar.Models.DarStatus.Rejected => "bg-danger",
        BTQCDar.Models.DarStatus.Cancelled => "bg-dark",
        _ => "bg-secondary"
    };
    string statusLabel = Model.Status switch
    {
        BTQCDar.Models.DarStatus.Draft => "Draft",
        BTQCDar.Models.DarStatus.PendingApproval => "Pending Approval",
        BTQCDar.Models.DarStatus.PendingMR => "Pending MR",
        BTQCDar.Models.DarStatus.PendingDCO => "Pending DCO",
        BTQCDar.Models.DarStatus.Completed => "Completed",
        BTQCDar.Models.DarStatus.Rejected => "Rejected",
        BTQCDar.Models.DarStatus.Cancelled => "Cancelled",
        _ => "Unknown"
    };
}

<!-- Header -->
<div class="d-flex align-items-center mt-3 mb-3 gap-2 flex-wrap">
    <h5 class="mb-0">
        <i class="bi bi-file-earmark-check me-1 text-dar"></i>
        @Model.DarNo
    </h5>
    <span class="badge @badgeClass ms-1">@statusLabel</span>
    <div class="ms-auto d-flex gap-2">
        @if (canEdit)
        {
            <a href="/Dar/Edit/@Model.DarId" class="btn btn-sm btn-outline-secondary">
                <i class="bi bi-pencil me-1"></i>Edit
            </a>
        }
        <button class="btn btn-sm btn-outline-secondary" id="btnAuditLog"
                data-darno="@Model.DarNo" title="Digital Signature Audit Log">
            <i class="bi bi-clock-history me-1"></i>Audit Log
        </button>
        <a href="/Dar/Index" class="btn btn-sm btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i>Back
        </a>
    </div>
</div>

<div class="row g-3">

    <!-- Type & For -->
    <div class="col-md-6">
        <div class="card shadow-sm h-100">
            <div class="card-header fw-semibold small">Document Type</div>
            <div class="card-body small">
                <div>
                    <strong>Type:</strong> @Model.DocType
                    @if (Model.DocType == BTQCDar.Models.DarDocType.Other)
                    {
                        <span>— @Model.DocTypeOther</span>
                    }
                </div>
                <div class="mt-1">
                    <strong>For:</strong> @Model.ForStandard
                    @if (Model.ForStandard == BTQCDar.Models.DarForStandard.Others)
                    {
                        <span>— @Model.ForStandardOther</span>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Document Info -->
    <div class="col-md-6">
        <div class="card shadow-sm h-100">
            <div class="card-header fw-semibold small">Document Information</div>
            <div class="card-body small">
                <div><strong>Document No:</strong> @(string.IsNullOrEmpty(Model.DocumentNo) ? "—" : Model.DocumentNo)</div>
                <div class="mt-1"><strong>Document Name:</strong> @Model.DocumentName</div>
                <div class="mt-1">
                    <strong>Purpose:</strong> @Model.Purpose
                    @if (Model.Purpose == BTQCDar.Models.DarPurpose.Others)
                    {
                        <span>— @Model.PurposeOther</span>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Content & Reason -->
    <div class="col-12">
        <div class="card shadow-sm">
            <div class="card-header fw-semibold small">Content &amp; Reason</div>
            <div class="card-body small">
                <p class="mb-1"><strong>Content:</strong> @Model.Content</p>
                @if (!string.IsNullOrEmpty(Model.ReasonBehindPurpose))
                {
                    <p class="mb-1"><strong>Reason:</strong> @Model.ReasonBehindPurpose</p>
                }
                <div class="d-flex flex-wrap gap-3 mt-2">
                    <span><strong>Effective Date:</strong> @(Model.EffectiveDate?.ToString("dd/MM/yyyy") ?? "—")</span>
                    <span><strong>Revision No:</strong> @(string.IsNullOrEmpty(Model.RevisionNo) ? "—" : Model.RevisionNo)</span>
                    <span>
                        <strong>Attachment:</strong>
                        @if (Model.HasAttachment && !string.IsNullOrEmpty(Model.AttachmentFileName))
                        {
                            <a href="/uploads/@Model.AttachmentFileName" target="_blank"
                               class="badge bg-success text-decoration-none">
                                <i class="bi bi-download me-1"></i>@Model.AttachmentFileName
                            </a>
                        }
                        else
                        {

                            <span class="text-muted">No attachment</span>
                        }
                    </span>
                </div>
            </div>
        </div>
    </div>

    <!-- Distribution -->
    @if (!string.IsNullOrEmpty(Model.DistributionList))
    {
        <div class="col-12">
            <div class="card shadow-sm">
                <div class="card-header fw-semibold small">Distribution List</div>
                <div class="card-body small">
                    <div class="mb-2">
                        @if (Model.IsControlledCopy)
                        {
                            <span class="badge bg-secondary me-1">Controlled Copy</span>
                        }
                        @if (Model.IsUncontrolledCopy)
                        {
                            <span class="badge bg-secondary me-1">Uncontrolled Copy</span>
                        }
                    </div>
                    <div>@Model.DistributionList</div>
                </div>
            </div>
        </div>
    }


    <!-- Workflow History -->
    <div class="col-12">
        <div class="card shadow-sm">
            <div class="card-header fw-semibold small">
                <i class="bi bi-diagram-3 me-1"></i>Approval Workflow
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-sm table-bordered small mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Step</th>
                                <th>Performed By</th>
                                <th>Date</th>
                                <th>Result</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>Requested by</td>
                                <td>@Model.RequestedByName</td>
                                <td>@Model.RequestedDate.ToString("dd/MM/yyyy")</td>
                                <td><span class="badge bg-success">Done</span></td>
                            </tr>
                            <tr>
                                <td>Reviewer</td>
                                <td>@(string.IsNullOrEmpty(Model.ReviewerName) ? (Model.ReviewerSamAcc ?? "—") : Model.ReviewerName)</td>
                                <td>@(Model.ReviewerSignedAt?.ToString("dd/MM/yyyy HH:mm") ?? Model.ReviewedDate?.ToString("dd/MM/yyyy") ?? "—")</td>
                                <td>
                                    @if (Model.ReviewerSignedAt.HasValue)
                                    {
                                        <span class="badge bg-success cert-badge"
                                              style="cursor:pointer"
                                              data-role="Reviewer"
                                              data-name="@Model.ReviewerName"
                                              data-samacc="@Model.ReviewerSamAcc"
                                              data-signedat="@Model.ReviewerSignedAt?.ToString("dd/MM/yyyy HH:mm")"
                                              data-thumbprint="@(Model.ReviewerCertThumbprint ?? "—")"
                                              title="Click to view certificate details">
                                            <i class="bi bi-shield-check me-1"></i>Digitally Signed
                                        </span>
                                    }
                                    else if (Model.ReviewedDate.HasValue)
                                    {

                                        <span class="badge bg-success">Reviewed</span>
                                    }
                                    else if (!string.IsNullOrEmpty(Model.ReviewerSamAcc))
                                    {

                                        <span class="badge bg-warning text-dark">Pending</span>
                                    }
                                    else
                                    {

                                        <span class="text-muted">—</span>
                                    }
                                </td>
                            </tr>
                            <tr>
                                <td>Approver</td>
                                <td>@(string.IsNullOrEmpty(Model.ApproverName) ? (Model.ApproverSamAcc ?? "—") : Model.ApproverName)</td>
                                <td>@(Model.ApprovedDate?.ToString("dd/MM/yyyy") ?? "—")</td>
                                <td>
                                    @if (Model.ApproverSignedAt.HasValue)
                                    {
                                        <span class="badge bg-success cert-badge"
                                              style="cursor:pointer"
                                              data-role="Approver"
                                              data-name="@Model.ApproverName"
                                              data-samacc="@Model.ApproverSamAcc"
                                              data-signedat="@Model.ApproverSignedAt?.ToString("dd/MM/yyyy HH:mm")"
                                              data-thumbprint="@(Model.ApproverCertThumbprint ?? "—")"
                                              title="Click to view certificate details">
                                            <i class="bi bi-shield-check me-1"></i>Digitally Signed
                                        </span>
                                    }
                                    else if (Model.ApprovedDate.HasValue)
                                    {

                                        <span class="badge bg-success">Approved</span>
                                    }
                                    else if (!string.IsNullOrEmpty(Model.ApproverSamAcc))
                                    {

                                        <span class="badge bg-warning text-dark">Pending</span>
                                    }
                                    else
                                    {

                                        <span class="text-muted">—</span>
                                    }
                                </td>
                            </tr>
                            <tr>
                                <td>Approved by</td>
                                <td>@(Model.ApprovedByName ?? "—")</td>
                                <td>@(Model.ApprovedDate?.ToString("dd/MM/yyyy") ?? "—")</td>
                                <td>
                                    @if (Model.ApprovedDate.HasValue)
                                    {
                                        <span class="badge bg-success">Approved</span>
                                    }
                                    else if (Model.Status == BTQCDar.Models.DarStatus.PendingApproval)
                                    {

                                        <span class="badge bg-warning text-dark">Pending</span>
                                    }
                                    else
                                    {

                                        <span class="text-muted">—</span>
                                    }
                                </td>
                            </tr>
                            <!-- DCO Section -->
                            <tr class="table-light">
                                <td colspan="4" class="fw-semibold small text-muted py-1 ps-3">
                                    <i class="bi bi-building me-1"></i>Document Control Officer
                                </td>
                            </tr>
                            <tr>
                                <td class="ps-4">QMR (role=2)</td>
                                <td>@(Model.MRSamAcc ?? "—")</td>
                                <td>@(Model.MRDate?.ToString("dd/MM/yyyy") ?? "—")</td>
                                <td>
                                    @if (Model.MRSignedAt.HasValue)
                                    {
                                        <span class="badge bg-success cert-badge" style="cursor:pointer"
                                              data-role="QMR" data-name="@Model.MRSamAcc"
                                              data-samacc="@Model.MRSamAcc"
                                              data-signedat="@Model.MRSignedAt?.ToString("dd/MM/yyyy HH:mm")"
                                              data-thumbprint="@(Model.MRCertThumbprint ?? "—")"
                                              title="Click to view certificate">
                                            <i class="bi bi-shield-check me-1"></i>Digitally Signed
                                        </span>
                                    }
                                    else if (Model.MRAgree == true)
                                    {

                                        <span class="badge bg-success">Agreed</span>
                                    }
                                    else if (Model.MRAgree == false)
                                    {

                                        <span class="badge bg-danger">Not Agreed</span>
                                    }
                                    else if (Model.Status == BTQCDar.Models.DarStatus.PendingDCO)
                                    {

                                        <span class="badge bg-warning text-dark">Pending</span>
                                    }
                                    else
                                    {

                                        <span class="text-muted">—</span>
                                    }
                                </td>
                            </tr>
                            <tr>
                                <td class="ps-4">DCC (role=1)</td>
                                <td>@(Model.DCOSamAcc ?? "—")</td>
                                <td>@(Model.DocRegisteredDate?.ToString("dd/MM/yyyy") ?? "—")</td>
                                <td>
                                    @if (Model.DCOSignedAt.HasValue)
                                    {
                                        <span class="badge bg-success cert-badge" style="cursor:pointer"
                                              data-role="DCC" data-name="@Model.DCOSamAcc"
                                              data-samacc="@Model.DCOSamAcc"
                                              data-signedat="@Model.DCOSignedAt?.ToString("dd/MM/yyyy HH:mm")"
                                              data-thumbprint="@(Model.DCOCertThumbprint ?? "—")"
                                              title="Click to view certificate">
                                            <i class="bi bi-shield-check me-1"></i>Digitally Signed
                                        </span>
                                    }
                                    else if (Model.DocRegisteredDate.HasValue)
                                    {

                                        <span class="badge bg-success">Completed</span>
                                    }
                                    else if (Model.Status == BTQCDar.Models.DarStatus.PendingDCO && Model.MRAgree == true)
                                    {

                                        <span class="badge bg-primary">Pending DCC</span>
                                    }
                                    else if (Model.Status == BTQCDar.Models.DarStatus.PendingDCO)
                                    {

                                        <span class="text-muted small">Waiting for QMR</span>
                                    }
                                    else
                                    {

                                        <span class="text-muted">—</span>
                                    }
                                </td>
                            </tr>
                            @if (!string.IsNullOrEmpty(Model.DCORemarks))
                            {
                                <tr>
                                    <td class="ps-4 text-muted small">DCC Remarks</td>
                                    <td colspan="3" class="small fst-italic text-secondary">
                                        <i class="bi bi-chat-left-text me-1"></i>@Model.DCORemarks
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(Model.Remarks))
    {
        <div class="col-12">
            <div class="alert alert-secondary small mb-0">
                <i class="bi bi-chat-left-text me-1"></i><strong>Remarks:</strong> @Model.Remarks
            </div>
        </div>
    }

</div>

<!-- Workflow Action Buttons -->
@if (canSignReview || canSignApprove || canReview || canApprove || canMR || canDCO)
{
    @Html.AntiForgeryToken()

    <div class="card shadow-sm mt-3 mb-4">
        <div class="card-header fw-semibold small">
            <i class="bi bi-play-circle me-1 text-dar"></i>Action
        </div>
        <div class="card-body d-flex flex-wrap gap-2">
            @if (canSignReview)
            {
                <button class="btn btn-success btn-sm fw-semibold" data-action="sign-review" data-id="@Model.DarId">
                    <i class="bi bi-shield-check me-1"></i>Sign &amp; Forward to Approver
                </button>
                <button class="btn btn-outline-success btn-sm" data-action="review" data-id="@Model.DarId">
                    <i class="bi bi-check2-square me-1"></i>Review (no signature)
                </button>
                <button class="btn btn-danger btn-sm" data-action="reject" data-id="@Model.DarId">
                    <i class="bi bi-x-circle me-1"></i>Reject
                </button>
            }
            @if (canSignApprove)
            {
                <button class="btn btn-success btn-sm fw-semibold" data-action="sign-approve" data-id="@Model.DarId">
                    <i class="bi bi-shield-check me-1"></i>Sign &amp; Approve
                </button>
                <button class="btn btn-outline-success btn-sm" data-action="approve" data-id="@Model.DarId">
                    <i class="bi bi-check-circle me-1"></i>Approve (no signature)
                </button>
                <button class="btn btn-danger btn-sm" data-action="reject" data-id="@Model.DarId">
                    <i class="bi bi-x-circle me-1"></i>Reject
                </button>
            }
            @if (canMR)
            {
                <div class="d-flex flex-column gap-1 border-start border-2 border-warning ps-3">
                    <small class="text-muted fw-semibold">QMR — Agreement Required</small>
                    <div class="d-flex gap-2">
                        <button class="btn btn-success btn-sm fw-semibold" data-action="sign-mr-agree" data-id="@Model.DarId">
                            <i class="bi bi-shield-check me-1"></i>Sign &amp; Agree
                        </button>
                        <button class="btn btn-outline-success btn-sm" data-action="mr-agree" data-id="@Model.DarId">
                            <i class="bi bi-check-circle me-1"></i>Agree (no signature)
                        </button>
                        <button class="btn btn-danger btn-sm" data-action="mr-disagree" data-id="@Model.DarId">
                            <i class="bi bi-x-circle me-1"></i>Not Agree
                        </button>
                    </div>
                </div>
            }
            @if (canDCO)
            {
                <div class="d-flex flex-column gap-1 border-start border-2 border-primary ps-3">
                    <small class="text-muted fw-semibold">DCC — Registration</small>
                    <div class="d-flex gap-2">
                        <button class="btn btn-primary btn-sm fw-semibold" data-action="sign-dco-register" data-id="@Model.DarId">
                            <i class="bi bi-shield-check me-1"></i>Sign &amp; Complete
                        </button>
                        <button class="btn btn-outline-primary btn-sm" data-action="dco-register" data-id="@Model.DarId">
                            <i class="bi bi-journal-check me-1"></i>Complete (no signature)
                        </button>
                    </div>
                </div>
            }
        </div>
    </div>

    <!-- Action Modal -->
    <div class="modal fade" id="modalAction" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="modalTitle">Confirm Action</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div id="dcoDateWrap" class="mb-3" style="display:none">
                        <label class="form-label small fw-semibold">Doc Registered Date <span class="text-danger">*</span></label>
                        <input type="date" id="dcoDate" class="form-control form-control-sm">
                    </div>
                    <div id="dcoRemarksWrap" class="mb-3" style="display:none">
                        <label class="form-label small fw-semibold">
                            <i class="bi bi-journal-text me-1"></i>DCC Remarks
                        </label>
                        <textarea id="dcoRemarks" class="form-control form-control-sm" rows="3"
                              placeholder="Enter DCC registration remarks..."></textarea>
                    </div>
                    <label class="form-label small fw-semibold">Remarks (optional)</label>
                    <textarea id="actionRemarks" class="form-control form-control-sm" rows="3"
                          placeholder="Enter remarks or reason..."></textarea>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-sm" id="btnConfirmAction">Confirm</button>
                </div>
            </div>
        </div>
    </div>
}

<!-- Audit Log Modal -->
<div class="modal fade" id="auditModal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header bg-secondary text-white py-2">
                <h6 class="modal-title mb-0">
                    <i class="bi bi-clock-history me-2"></i>Digital Signature Audit Log
                    <span id="auditDarNo" class="ms-2 fw-normal opacity-75"></span>
                </h6>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-0" id="auditModalBody">
                <div class="text-center py-4 text-muted">
                    <div class="spinner-border spinner-border-sm me-2"></div>Loading...
                </div>
            </div>
            <div class="modal-footer py-2">
                <small class="text-muted me-auto">
                    <i class="bi bi-info-circle me-1"></i>Source: BT Digital Signature System
                </small>
                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

<!-- Audit Log Modal -->
<div class="modal fade" id="auditModal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header bg-secondary text-white py-2">
                <h6 class="modal-title mb-0">
                    <i class="bi bi-clock-history me-2"></i>Digital Signature Audit Log
                    <span id="auditDarNo" class="ms-2 fw-normal opacity-75 small"></span>
                </h6>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-0" id="auditModalBody">
                <div class="text-center py-4 text-muted">
                    <div class="spinner-border spinner-border-sm me-2"></div>Loading...
                </div>
            </div>
            <div class="modal-footer py-2">
                <small class="text-muted me-auto">
                    <i class="bi bi-shield-lock me-1"></i>Source: BT Digital Signature System
                </small>
                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
</div>

<!-- Certificate Detail Modal -->
<div class="modal fade" id="certModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-success text-white py-2">
                <h6 class="modal-title mb-0">
                    <i class="bi bi-shield-check me-2"></i>Digital Signature Certificate
                </h6>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-0">
                <table class="table table-sm table-borderless mb-0 small">
                    <tbody>
                        <tr class="border-bottom">
                            <td class="text-muted fw-semibold ps-3 py-2" style="width:130px">Role</td>
                            <td class="py-2" id="cert-role"></td>
                        </tr>
                        <tr class="border-bottom">
                            <td class="text-muted fw-semibold ps-3 py-2">Signed By</td>
                            <td class="py-2" id="cert-name"></td>
                        </tr>
                        <tr class="border-bottom">
                            <td class="text-muted fw-semibold ps-3 py-2">SamAcc</td>
                            <td class="py-2 font-monospace" id="cert-samacc"></td>
                        </tr>
                        <tr class="border-bottom">
                            <td class="text-muted fw-semibold ps-3 py-2">Signed At</td>
                            <td class="py-2" id="cert-signedat"></td>
                        </tr>
                        <tr>
                            <td class="text-muted fw-semibold ps-3 py-2">Thumbprint</td>
                            <td class="py-2">
                                <code class="small text-break" id="cert-thumbprint"
                                      style="font-size:0.75rem;word-break:break-all"></code>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
            <div class="modal-footer py-2 bg-light">
                <small class="text-muted me-auto">
                    <i class="bi bi-info-circle me-1"></i>
                    Signed via BT Digital Signature System
                </small>
                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Close</button>
            </div>
        </div>
    </div>
