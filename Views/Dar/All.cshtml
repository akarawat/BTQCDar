@model List<BTQCDar.Models.DarListItemModel>
@{
    ViewData["Title"] = "All DARs";
    var q = ViewBag.Q as string ?? string.Empty;
    var status = ViewBag.Status as string ?? string.Empty;

    var statusOptions = new[] {
        new { Val = "",  Label = "All Status" },
        new { Val = "1", Label = "Pending Approval" },
        new { Val = "2", Label = "Pending MR" },
        new { Val = "3", Label = "Pending DCO" },
        new { Val = "4", Label = "Completed" },
        new { Val = "5", Label = "Rejected" },
        new { Val = "0", Label = "Draft" },
    };
}

<div class="d-flex align-items-center mt-3 mb-3 gap-2 flex-wrap">
    <h5 class="mb-0">
        <i class="bi bi-table me-1 text-dar"></i>All DARs
        <span class="badge bg-warning text-dark ms-1" style="font-size:0.65rem;">Admin</span>
    </h5>
    <span class="text-muted small ms-1">— @Model.Count record(s)</span>
</div>

<!-- Filter bar -->
<form method="get" action="/Dar/All" class="card border-0 shadow-sm mb-3">
    <div class="card-body py-2">
        <div class="row g-2 align-items-center">
            <div class="col-md-5">
                <div class="input-group input-group-sm">
                    <span class="input-group-text bg-white">
                        <i class="bi bi-search text-muted"></i>
                    </span>
                    <input type="text" name="q" value="@q"
                           class="form-control border-start-0"
                           placeholder="Search DAR No., Document Name, Requester...">
                </div>
            </div>
            <div class="col-md-3">
                <select name="status" class="form-select form-select-sm">
                    @foreach (var opt in statusOptions)
                    {
                        if (status == opt.Val)
                        {
                            <option value="@opt.Val" selected="selected">@opt.Label</option>
                        }
                        else
                        {
                            <option value="@opt.Val">@opt.Label</option>
                        }
                    }
                </select>
            </div>
            <div class="col-auto">
                <button type="submit" class="btn btn-primary btn-sm">
                    <i class="bi bi-funnel me-1"></i>Filter
                </button>
                <a href="/Dar/All" class="btn btn-outline-secondary btn-sm ms-1">
                    <i class="bi bi-x-circle me-1"></i>Clear
                </a>
            </div>
            <div class="col-auto ms-auto">
                <small class="text-muted">
                    <i class="bi bi-eye-slash me-1"></i>Visible to Admin only
                </small>
            </div>
        </div>
    </div>
</form>

<!-- Table -->
<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover table-sm mb-0">
                <thead class="table-dark">
                    <tr>
                        <th class="ps-3">DAR No.</th>
                        <th>Document No.</th>
                        <th>Document Name</th>
                        <th>Purpose</th>
                        <th>Requested By</th>
                        <th>Request Date</th>
                        <th class="text-center">Status</th>
                        <th class="text-center">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="8" class="text-center text-muted py-5">
                                <i class="bi bi-inbox display-6 d-block mb-2 opacity-25"></i>
                                No records found.
                            </td>
                        </tr>
                    }
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-3 fw-semibold">
                                <a href="/Dar/Detail/@item.DarId"
                                   class="text-decoration-none text-dar">
                                    @item.DarNo
                                </a>
                            </td>
                            <td class="text-muted small">@(item.DocumentNo == "" ? "—" : item.DocumentNo)</td>
                            <td>@item.DocumentName</td>
                            <td><small class="text-muted">@item.Purpose</small></td>
                            <td><small>@item.RequestedBy</small></td>
                            <td><small>@item.RequestedDate.ToString("dd/MM/yyyy")</small></td>
                            <td class="text-center">
                                <span class="badge @item.StatusBadgeClass">@item.StatusLabel</span>
                            </td>
                            <td class="text-center">
                                <a href="/Dar/Detail/@item.DarId"
                                   class="btn btn-sm btn-outline-secondary py-0"
                                   title="View Detail">
                                    <i class="bi bi-eye"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @if (Model.Any())
    {
        <!-- Summary footer -->
        <div class="card-footer bg-light py-2 d-flex gap-3 flex-wrap small text-muted">
            @{
                var counts = Model.GroupBy(x => x.Status)
                .Select(g => new { Label = g.First().StatusLabel, Count = g.Count() })
                .OrderBy(x => x.Label);
            }
            <span><i class="bi bi-list-ul me-1"></i>Total: <strong>@Model.Count</strong></span>
            @foreach (var s in counts)
            {
                <span>@s.Label: <strong>@s.Count</strong></span>
            }
        </div>
    }
</div>
