@model BTQCDar.Models.DarMasterModel
@{
    ViewData["Title"] = "Edit DAR: " + Model.DarNo;
}

<div class="mt-3 mb-2">
    <h5><i class="bi bi-pencil-square me-1 text-danger"></i>Edit DAR: @Model.DarNo</h5>
</div>

<form asp-action="Edit" asp-route-id="@Model.DarId" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="DarId" />
    <input type="hidden" asp-for="DarNo" />
    <input type="hidden" asp-for="RequestedBySamAcc" />
    <input type="hidden" asp-for="RequestedByName" />
    <input type="hidden" asp-for="RequestedDate" />
    <input type="hidden" asp-for="Status" />

    <!-- Document Type -->
    <div class="card border-0 shadow-sm mb-3">
        <div class="card-header bg-dar"><i class="bi bi-tag me-1"></i> Document Type</div>
        <div class="card-body">
            <div class="row g-2">
                @foreach (var t in new[] {
                                (1,"Policy / Objective / Manual"),
                                (2,"Standard Procedure"),
                                (3,"(Work/Inspection) Instruction"),
                                (4,"Form and Format"),
                                (5,"Supporting Document"),
                                (6,"Drawing"),
                                (7,"Document from External Origin"),
                                (8,"Other (Specify)")
                                })
                {
                    <div class="col-md-3">
                        <div class="form-check">
                            <input class="form-check-input" type="radio" name="DocType"
                                   value="@t.Item1" id="dt@(t.Item1)"
                                   @(Model.DocType == (BTQCDar.Models.DarDocType)t.Item1 ? "checked" : "") />
                            <label class="form-check-label" for="dt@(t.Item1)">@t.Item2</label>
                        </div>
                    </div>
                }
            </div>
            <div id="docTypeOtherGroup" class="mt-2 @(Model.DocType == BTQCDar.Models.DarDocType.Other ? "" : "d-none")">
                <input asp-for="DocTypeOther" class="form-control form-control-sm"
                       placeholder="Specify document type..." />
            </div>
        </div>
    </div>

    <!-- For Standard -->
    <div class="card border-0 shadow-sm mb-3">
        <div class="card-header bg-dar"><i class="bi bi-shield-check me-1"></i> For Standard</div>
        <div class="card-body">
            <div class="row g-2">
                @foreach (var s in new[] {
                                (1,"QMS / ISO 9001"),
                                (2,"EMS / ISO 14001"),
                                (3,"Safety / OHSAS / TIS 18001"),
                                (4,"Others (specify)")
                                })
                {
                    <div class="col-md-3">
                        <div class="form-check">
                            <input class="form-check-input" type="radio" name="ForStandard"
                                   value="@s.Item1" id="fs@(s.Item1)"
                                   @(Model.ForStandard == (BTQCDar.Models.DarForStandard)s.Item1 ? "checked" : "") />
                            <label class="form-check-label" for="fs@(s.Item1)">@s.Item2</label>
                        </div>
                    </div>
                }
            </div>
            <div id="forStandardOtherGroup" class="mt-2 @(Model.ForStandard == BTQCDar.Models.DarForStandard.Others ? "" : "d-none")">
                <input asp-for="ForStandardOther" class="form-control form-control-sm"
                       placeholder="Specify standard..." />
            </div>
        </div>
    </div>

    <!-- Document Information -->
    <div class="card border-0 shadow-sm mb-3">
        <div class="card-header bg-dar"><i class="bi bi-file-text me-1"></i> Document Information</div>
        <div class="card-body row g-2">
            <div class="col-md-4">
                <label class="form-label fw-semibold small">Document No.</label>
                <input asp-for="DocumentNo" class="form-control form-control-sm" />
            </div>
            <div class="col-md-8">
                <label class="form-label fw-semibold small">
                    Document Name <span class="text-danger">*</span>
                </label>
                <input asp-for="DocumentName" class="form-control form-control-sm" required />
            </div>
        </div>
    </div>

    <!-- Purpose -->
    <div class="card border-0 shadow-sm mb-3">
        <div class="card-header bg-dar"><i class="bi bi-bullseye me-1"></i> Purpose</div>
        <div class="card-body">
            <div class="row g-2">
                @foreach (var p in new[] {
                                (1,"Issue new document"),
                                (2,"Receive from external origin"),
                                (3,"Change / Update / Revise"),
                                (4,"Add distribution (Control copy)"),
                                (5,"Request copy (Un-Control copy)"),
                                (6,"Cancel document"),
                                (7,"Others (Specify)")
                                })
                {
                    <div class="col-md-4">
                        <div class="form-check">
                            <input class="form-check-input" type="radio" name="Purpose"
                                   value="@p.Item1" id="pur@(p.Item1)"
                                   @(Model.Purpose == (BTQCDar.Models.DarPurpose)p.Item1 ? "checked" : "") />
                            <label class="form-check-label" for="pur@(p.Item1)">@p.Item2</label>
                        </div>
                    </div>
                }
            </div>
            <div id="purposeOtherGroup" class="mt-2 @(Model.Purpose == BTQCDar.Models.DarPurpose.Others ? "" : "d-none")">
                <input asp-for="PurposeOther" class="form-control form-control-sm"
                       placeholder="Specify purpose..." />
            </div>
        </div>
    </div>

    <!-- Content & Reason -->
    <div class="card border-0 shadow-sm mb-3">
        <div class="card-header bg-dar"><i class="bi bi-card-text me-1"></i> Content &amp; Reason</div>
        <div class="card-body row g-3">
            <div class="col-12">
                <label class="form-label fw-semibold small">Content of Document or Change</label>
                <textarea asp-for="Content" class="form-control" rows="3"></textarea>
            </div>
            <div class="col-12 d-flex gap-4 align-items-center">
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" asp-for="HasAttachment" id="hasAttach" />
                    <label class="form-check-label" for="hasAttach">Have attachment</label>
                </div>
                <div>
                    <label class="form-label fw-semibold small mb-0">Status of Document Under Request</label>
                    <input asp-for="DocStatusUnderRequest" class="form-control form-control-sm"
                           style="max-width:200px" />
                </div>
            </div>
            <div class="col-12">
                <label class="form-label fw-semibold small">Describe reason behind purpose</label>
                <textarea asp-for="ReasonBehindPurpose" class="form-control" rows="2"></textarea>
            </div>
            <div class="col-md-4">
                <label class="form-label fw-semibold small">Effective Date</label>
                <input asp-for="EffectiveDate" type="date" class="form-control form-control-sm" />
            </div>
            <div class="col-md-4">
                <label class="form-label fw-semibold small">Revision No.</label>
                <input asp-for="RevisionNo" class="form-control form-control-sm" />
            </div>
        </div>
    </div>

    <!-- Distribution List -->
    <div class="card border-0 shadow-sm mb-3">
        <div class="card-header bg-dar"><i class="bi bi-people me-1"></i> Distribution List</div>
        <div class="card-body">
            <div class="d-flex gap-4 mb-2">
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" asp-for="IsControlledCopy" />
                    <label class="form-check-label">Controlled Copy</label>
                </div>
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" asp-for="IsUncontrolledCopy" />
                    <label class="form-check-label">Uncontrolled Copy</label>
                </div>
            </div>
            <textarea asp-for="DistributionList" class="form-control" rows="2"></textarea>
        </div>
    </div>

    <div class="d-flex gap-2 justify-content-end mb-4">
        <a href="/Dar/Detail/@Model.DarId" class="btn btn-secondary">
            <i class="bi bi-x-circle me-1"></i>Cancel
        </a>
        <button type="submit" class="btn btn-danger">
            <i class="bi bi-floppy me-1"></i>Save Changes
        </button>
    </div>
</form>
