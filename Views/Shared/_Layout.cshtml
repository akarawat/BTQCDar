                <i class="bi bi-file-earmark-check me-1"></i>
                @BTQCDar.Constants.AppShort
                <small class="fw-normal fs-6 ms-1 d-none d-md-inline">| @BTQCDar.Constants.AppTitle</small>
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMain">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navMain">
                @{
                    // Declare _user ONCE at the top — reused in both nav menus
                    var _json = Context.Session.GetString("UserSession");
                    BTQCDar.Models.UserSessionModel? _user = null;
                    if (!string.IsNullOrEmpty(_json))
                        _user = System.Text.Json.JsonSerializer.Deserialize<BTQCDar.Models.UserSessionModel>(_json);
                }
                <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                    <li class="nav-item">
                        <a class="nav-link" href="/Dashboards/Index"><i class="bi bi-house me-1"></i>Home</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/Dar/Create"><i class="bi bi-plus-circle me-1"></i>New DAR</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/Dar/Index"><i class="bi bi-list-ul me-1"></i>My DARs</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/Dar/History">
                            <i class="bi bi-clock-history me-1"></i>History
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/Dar/Pending">
                            <i class="bi bi-inbox me-1"></i>Pending Actions
                            <span id="navPendingBadge"
                                  class="badge rounded-pill bg-danger ms-1"
                                  style="display:none;font-size:0.7rem;vertical-align:middle"></span>
                        </a>
                    </li>
                    @if (_user != null && _user.IsAdmin)
                    {
                        <li class="nav-item">
                            <a class="nav-link" href="/Admin/UserApprovalRoles">
                                <i class="bi bi-shield-check me-1"></i>User Approval Roles
                            </a>
                        </li>
                    }
                </ul>
                @if (_user != null)
                {
                    <ul class="navbar-nav">
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                                <i class="bi bi-person-circle me-1"></i>@_user.FullName
                                @if (_user.IsAdmin)
                                {
                                    <span class="badge bg-warning text-dark ms-1">Admin</span>
                                }
                                @if (_user.IsMR)
                                {
                                    <span class="badge bg-info text-dark ms-1">MR</span>
                                }
                                @if (_user.IsDCO)
                                {
                                    <span class="badge bg-primary ms-1">DCO</span>
                                }
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li><span class="dropdown-item-text small text-muted">@_user.SamAcc | @_user.DepName</span></li>
                                <li><hr class="dropdown-divider" /></li>
                                <li>
                                    <a class="dropdown-item text-danger" href="/Dashboards/Logout">
                                        <i class="bi bi-box-arrow-right me-1"></i>Logout
                                    </a>
                                </li>
                            </ul>
                        </li>
                    </ul>
                }
            </div>

        </div>
    </nav>

    <div class="page-wrapper">
        <div class="container-xl">

            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible alert-auto-dismiss fade show mt-2" role="alert">
                    <i class="bi bi-check-circle me-1"></i> @TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible alert-auto-dismiss fade show mt-2" role="alert">
                    <i class="bi bi-exclamation-triangle me-1"></i> @TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            @RenderBody()
        </div>
    </div>

    <footer>
        &copy; @DateTime.Now.Year @BTQCDar.Constants.Company &nbsp;|&nbsp;
        @BTQCDar.Constants.AppName <a href="/cdn-cgi/l/email-protection" class="__cf_email__" data-cfemail="196f595b4d485a5d786b375a76776a6d78776d6a375869694f7c6b6a707677">[email&#160;protected]</a>
    </footer>

    @* <script src="https://cdn.jsdelivr.net/npm/jquery@3.7.1/dist/jquery.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
 *@
    <script src="~/js/jquery.min.js"></script>
    <script src="~/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
